#!/usr/bin/env bash
# adg — bootstrap wrapper shipped with the write-adr plugin.
#
# Claude Code prepends this plugin's bin/ to the Bash tool's PATH while the plugin
# is enabled, so the skills' bare `adg …` calls resolve here. On first use this
# wrapper downloads the prebuilt `adg` binary matching the plugin's pinned version
# (read from plugin.json) into a persistent cache, verifies its sha256, and execs
# it. No Go toolchain required; subsequent calls hit the cache.
#
# Escape hatches (checked before any download):
#   ADG_BIN=/path/to/adg    use this binary verbatim (dev / offline)
#   ADG_PREFER_SYSTEM=1      use a real `adg` found elsewhere on PATH
#   ADG_REPO=owner/repo      override the GitHub repo (default: from plugin.json homepage)
#   ADG_BASE_URL=...         override the release base URL (testing / internal mirror)
set -euo pipefail

die() { echo "adg (write-adr wrapper): $*" >&2; exit 1; }

# 0. explicit binary override --------------------------------------------------
if [ -n "${ADG_BIN:-}" ] && [ -x "${ADG_BIN}" ]; then
    exec "${ADG_BIN}" "$@"
fi

# locate this script and the plugin root --------------------------------------
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do self="$(readlink "$self")"; done
self_real="$(cd "$(dirname "$self")" && pwd)/$(basename "$self")"
root="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$self_real")/.." && pwd)}"
manifest="$root/.claude-plugin/plugin.json"

# 1. opt-in: defer to a real system adg ---------------------------------------
if [ "${ADG_PREFER_SYSTEM:-}" = "1" ]; then
    while IFS= read -r cand; do
        [ -n "$cand" ] || continue
        cand_real="$(cd "$(dirname "$cand")" 2>/dev/null && pwd)/$(basename "$cand")" || continue
        if [ "$cand_real" != "$self_real" ] && [ -x "$cand_real" ]; then
            exec "$cand_real" "$@"
        fi
    done < <(type -ap adg 2>/dev/null || true)
fi

# 2. read the pinned version + repo from plugin.json --------------------------
[ -f "$manifest" ] || die "plugin manifest not found at $manifest"
read_json() { # read_json <top-level-string-key>
    if command -v jq >/dev/null 2>&1; then
        jq -r ".$1 // empty" "$manifest"
    else
        sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" "$manifest" | head -n1
    fi
}
version="$(read_json version)"
[ -n "$version" ] || die "could not read \"version\" from $manifest"
repo="${ADG_REPO:-}"
if [ -z "$repo" ]; then
    home="$(read_json homepage)"            # https://github.com/owner/repo
    repo="${home#https://github.com/}"; repo="${repo%/}"
fi
[ -n "$repo" ] || repo="daniellemccool/ad-guidance-tool"

# 3. map platform to the goreleaser os/arch asset name ------------------------
case "$(uname -s)" in
    Linux)               os=linux ;;
    Darwin)              os=darwin ;;
    MINGW*|MSYS*|CYGWIN*) os=windows ;;
    *) die "unsupported OS: $(uname -s)" ;;
esac
case "$(uname -m)" in
    x86_64|amd64)  arch=amd64 ;;
    arm64|aarch64) arch=arm64 ;;
    *) die "unsupported architecture: $(uname -m)" ;;
esac
ext=""; [ "$os" = windows ] && ext=".exe"
asset="adg_${os}_${arch}${ext}"

# 4. cache (persistent across plugin updates), keyed by version ---------------
data="${CLAUDE_PLUGIN_DATA:-${XDG_CACHE_HOME:-$HOME/.cache}/adg-plugin}"
cache_dir="$data/bin/$version"
bin="$cache_dir/adg${ext}"
[ -x "$bin" ] && exec "$bin" "$@"

# 5. download + verify + atomic install ---------------------------------------
base="${ADG_BASE_URL:-https://github.com/$repo/releases/download/v$version}"
mkdir -p "$cache_dir"
tmp="$(mktemp "$cache_dir/.adg.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

fetch() { # fetch <url> <out>
    if command -v curl >/dev/null 2>&1; then curl -fsSL "$1" -o "$2"
    elif command -v wget >/dev/null 2>&1; then wget -qO "$2" "$1"
    else die "need curl or wget to download adg"; fi
}

if ! fetch "$base/$asset" "$tmp"; then
    die "could not download $asset
    tried: $base/$asset
    The first use of adg (per plugin version) needs network access. To work offline:
      - download a prebuilt adg from  https://github.com/$repo/releases  then run:
          export ADG_BIN=/path/to/adg
      - or install it system-wide / build from source (see the repo README)."
fi

# checksum: best-effort — verify when checksums.txt is reachable and lists the asset
sums="$(mktemp "$cache_dir/.sums.XXXXXX")"
trap 'rm -f "$tmp" "$sums"' EXIT
if fetch "$base/checksums.txt" "$sums" 2>/dev/null; then
    want="$(awk -v a="$asset" '$2 == a {print $1}' "$sums")"
    if [ -n "$want" ]; then
        if command -v sha256sum >/dev/null 2>&1; then got="$(sha256sum "$tmp" | awk '{print $1}')"
        elif command -v shasum >/dev/null 2>&1; then got="$(shasum -a 256 "$tmp" | awk '{print $1}')"
        else got=""; fi
        [ -z "$got" ] || [ "$got" = "$want" ] || die "checksum mismatch for $asset (got $got, want $want)"
    fi
fi

chmod +x "$tmp"
mv -f "$tmp" "$bin"   # atomic within the same filesystem
trap 'rm -f "$sums"' EXIT
exec "$bin" "$@"
