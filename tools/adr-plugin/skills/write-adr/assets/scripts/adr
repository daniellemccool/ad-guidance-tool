#!/usr/bin/env bash
# adr — optional repo-local wrapper around `adg` for a single flat model.
#
# Hardcodes the model path and exposes short, positional subcommands so callers
# (humans or agents) don't have to repeat --model or remember flag names. Body
# content for `edit` flows in via `adg edit --from-stdin` (a whole MADR body).
#
# The model defaults to docs/decisions; override with ADR_MODEL.
# Drop to bare `adg <cmd>` for any flag this wrapper doesn't expose.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[[ -n "$REPO_ROOT" ]] || { echo "adr: not in a git repo" >&2; exit 1; }
cd "$REPO_ROOT"

MODEL="${ADR_MODEL:-docs/decisions}"
AUTHOR="${ADR_AUTHOR:-$(git config user.name 2>/dev/null || echo "unknown")}"

usage() {
    cat >&2 <<USAGE
adr — wrapper around \`adg\` for $MODEL (override via ADR_MODEL).

Subcommands:
  new <title> [<id>]                       create a proposed ADR; ID is printed to stdout.
                                           Optional <id> (1-9999) for deterministic assignment.
  edit <id> [--force] < body               replace body via stdin (--force for non-proposed)
  decide <id> <option-or-index> [<r>] [--force]
                                           mark as accepted with the chosen option;
                                           <option> accepts the bullet text OR a 1-based index.
                                           --force overwrites an authored Decision Outcome.
  supersede <new> <old> [<reason>] [--force]
                                           bidirectional supersession
  comment <id> <text>                      append a comment; author from \$ADR_AUTHOR or git
  tag <id> <tag>...                        add one or more tags
  link <src> <dst> [<tag>] [<rev>]         within-model link, optional custom tags
  list [filter...]                         list ADRs; extra args pass through to \`adg list\`
  view <id> [--section ...]                show one ADR or selected sections
  validate                                 run adg validate

For decide/supersede, a leading non-flag positional is the rationale; any argument
starting with \`-\` (e.g. --force) passes through to \`adg\`. For flag detail on any
underlying command, see \`adg <cmd> --help\`.
USAGE
}

cmd="${1:-}"
shift || true

case "$cmd" in
    new)
        title="${1:?usage: adr new <title> [<id>]}"
        id="${2:-}"
        if [[ -n "$id" ]]; then
            adg add --title "$title" --id "$id" --model "$MODEL"
        else
            adg add --title "$title" --model "$MODEL"
        fi
        ;;
    edit)
        id="${1:?usage: adr edit <id> [--force] < body}"
        shift
        adg edit --id "$id" --from-stdin --model "$MODEL" "$@"
        ;;
    decide)
        id="${1:?usage: adr decide <id> <option> [<rationale>] [adg flags...]}"
        option="${2:?usage: adr decide <id> <option> [<rationale>] [adg flags...]}"
        shift 2
        # Leading non-flag positional is the rationale; the first '-' arg onward
        # (e.g. --force) passes through. Works with or without a rationale.
        rationale=""
        if [[ $# -gt 0 && "$1" != -* ]]; then rationale="$1"; shift; fi
        if [[ -n "$rationale" ]]; then
            adg decide --id "$id" --option "$option" --rationale "$rationale" --model "$MODEL" "$@"
        else
            adg decide --id "$id" --option "$option" --model "$MODEL" "$@"
        fi
        ;;
    supersede)
        new_id="${1:?usage: adr supersede <new> <old> [<rationale>] [adg flags...]}"
        old_id="${2:?usage: adr supersede <new> <old> [<rationale>] [adg flags...]}"
        shift 2
        rationale=""
        if [[ $# -gt 0 && "$1" != -* ]]; then rationale="$1"; shift; fi
        if [[ -n "$rationale" ]]; then
            adg supersede --new "$new_id" --old "$old_id" --rationale "$rationale" --model "$MODEL" "$@"
        else
            adg supersede --new "$new_id" --old "$old_id" --model "$MODEL" "$@"
        fi
        ;;
    comment)
        id="${1:?usage: adr comment <id> <text>}"
        text="${2:?usage: adr comment <id> <text>}"
        adg comment --id "$id" --text "$text" --author "$AUTHOR" --model "$MODEL"
        ;;
    tag)
        id="${1:?usage: adr tag <id> <tag>...}"
        shift
        [[ $# -gt 0 ]] || { echo "usage: adr tag <id> <tag>..." >&2; exit 1; }
        for tag in "$@"; do
            adg tag --id "$id" --tag "$tag" --model "$MODEL"
        done
        ;;
    link)
        src="${1:?usage: adr link <src> <dst> [<tag>] [<reverse-tag>]}"
        dst="${2:?usage: adr link <src> <dst> [<tag>] [<reverse-tag>]}"
        tag="${3:-}"
        reverse="${4:-}"
        args=(--from "$src" --to "$dst" --model "$MODEL")
        [[ -n "$tag" ]] && args+=(--tag "$tag")
        [[ -n "$reverse" ]] && args+=(--reverse-tag "$reverse")
        adg link "${args[@]}"
        ;;
    list)
        adg list --model "$MODEL" "$@"
        ;;
    view)
        id="${1:?usage: adr view <id> [--section ...]}"
        shift
        adg view --id "$id" --model "$MODEL" "$@"
        ;;
    validate)
        adg validate --model "$MODEL"
        ;;
    -h|--help|help|"")
        usage
        ;;
    *)
        echo "adr: unknown subcommand $cmd" >&2
        usage
        exit 1
        ;;
esac
